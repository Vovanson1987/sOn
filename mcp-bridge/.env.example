# ===== MCP Bridge runtime =====
PORT=4100
BRIDGE_HOST=0.0.0.0
MCP_PATH=/mcp
HEALTH_PATH=/health
MCP_BACKEND_DEFAULT=claude
LOG_LEVEL=info

# ===== Security =====
# Required in production
BRIDGE_AUTH_TOKEN=replace-with-long-random-token

# Comma-separated list of allowed origins; supports "*" and wildcard patterns.
# Example: https://studio.msty.app,https://*.msty.app
ALLOWED_ORIGINS=https://studio.msty.app

# If true, reject requests without Origin header.
STRICT_ORIGIN_CHECK=false

# ===== Limits =====
REQUEST_TIMEOUT_MS=120000
MAX_BODY_BYTES=1048576
SESSION_TTL_MS=1800000
SESSION_CLEANUP_INTERVAL_MS=60000
CONNECT_TIMEOUT_MS=15000

# ===== Upstream transport =====
# legacy-sse or streamable-http
UPSTREAM_TRANSPORT=legacy-sse

# Used when UPSTREAM_TRANSPORT=legacy-sse
UPSTREAM_SSE_URL=http://127.0.0.1:8790/sse

# Used when UPSTREAM_TRANSPORT=streamable-http
UPSTREAM_HTTP_URL=http://127.0.0.1:8791/mcp

# Optional auth to upstream
UPSTREAM_AUTH_BEARER=

# Optional JSON headers map forwarded to upstream
# UPSTREAM_HEADERS_JSON={"X-Api-Key":"your-key"}
UPSTREAM_HEADERS_JSON=

# Only if upstream uses self-signed certs (avoid in prod)
UPSTREAM_INSECURE_TLS=false

# ===== Multi-backend wrapper (legacy SSE upstream) =====
CLAUDE_ENABLED=true
CLAUDE_BIN=/home/son/.local/bin/claude
CLAUDE_ARGS=mcp serve
CLAUDE_CWD=/home/son/sOn
CLAUDE_WRAPPER_HOST=127.0.0.1
CLAUDE_WRAPPER_PORT=8790
CLAUDE_WRAPPER_IDLE_TIMEOUT_MS=900000

CODEX_REMOTE_ENABLED=true
CODEX_SSH_BIN=ssh
CODEX_SSH_TARGET=mac
CODEX_REMOTE_CMD=/opt/homebrew/bin/codex mcp-server
CODEX_REMOTE_CONNECT_TIMEOUT_MS=8000
