{
  "$schema": "https://raw.githubusercontent.com/nicegui/tauri2/master/schema.json",
  "productName": "sOn Messenger",
  "version": "1.0.0",
  "identifier": "com.son.desktop",
  "build": {
    "frontendDist": "../../webApp/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../../webApp && npm run dev",
    "beforeBuildCommand": "cd ../../webApp && npm run build"
  },
  "app": {
    "title": "sOn Messenger",
    "windows": [
      {
        "title": "sOn Messenger",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  }
}
