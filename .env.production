# sOn Messenger — Production переменные
# Скопируйте в .env и заполните реальными значениями

# PostgreSQL
POSTGRES_USER=son
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
POSTGRES_DB=son_prod

# JWT (минимум 32 символа)
JWT_SECRET=CHANGE_ME_random_jwt_secret_minimum_32_characters

# MinIO
MINIO_ACCESS_KEY=CHANGE_ME_minio_access
MINIO_SECRET_KEY=CHANGE_ME_minio_secret

# Порт (80 для HTTP, 443 для HTTPS через reverse proxy)
WEB_PORT=80
