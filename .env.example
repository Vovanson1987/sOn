# sOn Messenger — переменные окружения
# Скопируйте в .env и заполните значения

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=son_dev

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-совместимое хранилище)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Phoenix Gateway
SECRET_KEY_BASE=change-me-to-a-random-64-byte-string
GUARDIAN_SECRET=change-me-to-a-random-secret-key
PORT=4000

# TURN/STUN (coturn)
TURN_SECRET=son-turn-secret

# Kafka
KAFKA_BROKERS=kafka:9092

# MCP Bridge (Msty Studio/Desktop -> multi-backend wrapper)
MCP_BRIDGE_PORT=4100
MCP_BRIDGE_AUTH_TOKEN=change-me-long-random-token
MCP_BRIDGE_ALLOWED_ORIGINS=https://studio.msty.app
MCP_BACKEND_DEFAULT=claude
MCP_BRIDGE_UPSTREAM_TRANSPORT=legacy-sse
MCP_BRIDGE_UPSTREAM_SSE_URL=http://host.docker.internal:8790/sse
MCP_BRIDGE_UPSTREAM_HTTP_URL=http://host.docker.internal:8791/mcp
MCP_BRIDGE_UPSTREAM_AUTH_BEARER=
MCP_BRIDGE_UPSTREAM_HEADERS_JSON=

# Claude wrapper process
CLAUDE_BIN=/home/son/.local/bin/claude
CLAUDE_ARGS=mcp serve
CLAUDE_CWD=/home/son/sOn
CLAUDE_WRAPPER_PORT=8790
CLAUDE_WRAPPER_IDLE_TIMEOUT_MS=900000

# Codex backend via SSH to Mac
CODEX_REMOTE_ENABLED=true
CODEX_SSH_TARGET=mac
CODEX_REMOTE_CMD=/opt/homebrew/bin/codex mcp-server
CODEX_REMOTE_CONNECT_TIMEOUT_MS=8000

# MCP monitoring
MCP_ALERT_WEBHOOK_URL=
MCP_ALERT_TELEGRAM_BOT_TOKEN=
MCP_ALERT_TELEGRAM_CHAT_ID=
MCP_ALERT_TELEGRAM_API_BASE=https://api.telegram.org
