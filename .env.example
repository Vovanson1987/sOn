# sOn Messenger — переменные окружения
# Скопируйте в .env и заполните значения

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=son_dev

# Redis
REDIS_URL=redis://localhost:6379

# MinIO (S3-совместимое хранилище)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Phoenix Gateway
SECRET_KEY_BASE=change-me-to-a-random-64-byte-string
GUARDIAN_SECRET=change-me-to-a-random-secret-key
PORT=4000

# TURN/STUN (coturn)
TURN_SECRET=son-turn-secret

# Kafka
KAFKA_BROKERS=kafka:9092
